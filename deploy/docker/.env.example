# 开发环境配置示例
# 复制此文件为 .env 并修改配置

# 应用配置
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=contract

# Oracle 数据库配置
# 格式: oracle://username:password@host:port/service_name
ORACLE_DSN=oracle://read_db:Skhb1189!@172.16.15.6:1521/oadata
ORACLE_USERNAME=read_db
ORACLE_PASSWORD=Skhb1189!
ORACLE_INSTANT_CLIENT=/opt/oracle/instantclient

# 数据库连接池配置
DATABASE_MIN_CONNECTIONS=2
DATABASE_MAX_CONNECTIONS=10
DATABASE_CONNECT_TIMEOUT=30
DATABASE_COMMAND_TIMEOUT=60

# 日志配置
LOGGING_LEVEL=DEBUG
LOGGING_FILE_PATH=/app/logs/app.log

# 模板配置
TEMPLATE_PATH=/app/templates
TEMPLATE_OUTPUT_DIR=/app/output
TEMPLATE_MAX_FILE_SIZE=10485760

# 下载配置
DOWNLOADS_STORAGE_DIR=/app/output/downloads
DOWNLOADS_BASE_URL=http://localhost:8000
DOWNLOADS_URL_PATH=/static/downloads
DOWNLOADS_EXPIRES_IN=86400
DOWNLOADS_DISK_SPACE_THRESHOLD=80

# 安全配置
SECURITY_API_KEYS=[{"key":"sk_dev_xxxxx","name":"开发环境","enabled":true}]
