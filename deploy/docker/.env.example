# Docker 部署环境配置
# 复制此文件为 .env 并修改配置

# =============================================================================
# 必需配置
# =============================================================================

# Oracle 数据库连接
# 格式: oracle://username:password@host:port/service_name
ORACLE_DSN=oracle://read_db:YourPassword@172.16.15.6:1521/oadata

# API Key 列表（JSON 格式）
# 格式: [{"key":"密钥","name":"名称","enabled":true,"description":"描述"}]
# 注意: JSON 中的双引号需要用 \" 转义，或使用单引号包裹整个 JSON
SECURITY_API_KEYS=[{"key":"sk_prod_yourkey_here","name":"生产环境","enabled":true,"description":"生产环境API密钥"}]

# =============================================================================
# 可选配置
# =============================================================================

# 应用配置
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库连接池配置
DATABASE_MIN_CONNECTIONS=5
DATABASE_MAX_CONNECTIONS=20
DATABASE_CONNECT_TIMEOUT=30
DATABASE_COMMAND_TIMEOUT=60

# 日志配置
LOGGING_LEVEL=INFO

# 下载配置
DOWNLOADS_BASE_URL=http://localhost:8000
DOWNLOADS_EXPIRES_IN=86400
DOWNLOADS_DISK_SPACE_THRESHOLD=80

# ==================== 泛微OA配置 ====================
# OA服务器地址（多个用逗号分隔）
WEAVER_HOSTS=172.16.14.6:8080,172.16.14.19:8080
# OA系统标识
WEAVER_SYSTEM_ID=SalesContract_PriceUrl_Update
# OA MD5签名密码
WEAVER_PASSWORD=your_password_here
# OA操作人ID
WEAVER_OPERATOR_ID=5288
# 请求超时（秒）
WEAVER_TIMEOUT=30
